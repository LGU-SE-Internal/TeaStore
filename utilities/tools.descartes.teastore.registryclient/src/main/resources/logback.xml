<?xml version="1.0" encoding="UTF-8"?>
<!--
  Plain logback configuration. Log/trace correlation and OTLP export are owned
  entirely by the OpenTelemetry Java agent: its logback-appender instrumentation
  intercepts records from this CONSOLE appender, stamps the active span's
  trace_id/span_id, and ships them via OTLP. Do NOT add an OpenTelemetryAppender
  here — a bundled one runs against the app's own SDK instance, not the agent's,
  which breaks correlation (logs arrive without TraceId).
-->
<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} trace_id=%X{trace_id} span_id=%X{span_id} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <!-- Framework loggers at INFO so request-path logs (Jersey/EclipseLink/Ribbon)
         flow through logback and get stamped with the active span's TraceId by the
         agent. Keep io.opentelemetry at WARN to avoid agent self-noise. -->
    <logger name="com.netflix" level="INFO"/>
    <logger name="org.eclipse.persistence" level="INFO"/>
    <logger name="org.glassfish" level="INFO"/>
    <logger name="io.opentelemetry" level="WARN"/>
</configuration>
